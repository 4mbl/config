{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Browser",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": { "*": ["${configDir}/src/*"] },
    "types": [],
    "noEmit": true,
    "sourceMap": true
  }
}
